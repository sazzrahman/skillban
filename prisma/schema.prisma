// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  displayName   String?
  streakCount   Int       @default(0)
  lastActive    DateTime?
  tier          String    @default("free") // 'free' | 'base' | 'advanced'
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  conceptSkills     UserConceptSkill[]
  challengeAttempts UserChallengeAttempt[]
  accounts          Account[]
  sessions          Session[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Language {
  id     String  @id @default(uuid())
  slug   String  @unique // 'javascript', 'react', 'swift', etc.
  name   String
  active Boolean @default(true)

  concepts Concept[]
}

model Concept {
  id            String    @id @default(uuid())
  languageId    String
  slug          String
  name          String
  description   String?
  difficulty    Int?
  prerequisites String[]  // concept IDs that should be learned first
  createdAt     DateTime  @default(now())

  language        Language              @relation(fields: [languageId], references: [id])
  userConceptSkills UserConceptSkill[]
  challenges      Challenge[]

  @@unique([languageId, slug])
}

model UserConceptSkill {
  id          String    @id @default(uuid())
  userId      String
  conceptId   String
  score       Int       @default(0)
  attempts    Int       @default(0)
  lastAttempt DateTime?
  status      String    @default("unseen") // 'unseen' | 'struggling' | 'in_progress' | 'proficient'

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept Concept  @relation(fields: [conceptId], references: [id])

  @@unique([userId, conceptId])
}

model Challenge {
  id           String   @id @default(uuid())
  conceptId    String
  prompt       String   @db.Text
  analogy      String?  @db.Text
  scaffold     String?  @db.Text
  testCases    Json
  difficulty   Int?
  generatedBy  String?  // 'ai' | 'manual'
  aiProvider   String?  // 'deepseek' | 'qwen' | 'gemini'
  createdAt    DateTime @default(now())

  concept          Concept               @relation(fields: [conceptId], references: [id])
  attempts         UserChallengeAttempt[]
}

model UserChallengeAttempt {
  id           String    @id @default(uuid())
  userId       String
  challengeId  String
  code         String    @db.Text
  passed       Boolean
  testResults  Json?
  timeTaken    Int?      // Seconds
  hintUsed     Boolean   @default(false)
  attemptedAt  DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id])
}
