# Database
# CockroachDB connection string (Postgres-compatible)
DATABASE_URL="postgresql://user:password@host:26257/database?sslmode=verify-full"

# NextAuth.js
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# AI API Keys (for future AI integration)
# DeepSeek API key for AI challenge generation
DEEPSEEK_API_KEY=""

# Qwen API key for AI challenge generation
QWEN_API_KEY=""

# Google Gemini API key for AI challenge generation
GEMINI_API_KEY=""

# Code Execution Sandbox
# Piston API URL (self-hosted or public)
PISTON_API_URL="https://emkc.org/api/v2/piston"

# Optional: Rate limiting
# Redis URL for rate limiting (production)
# REDIS_URL=""
